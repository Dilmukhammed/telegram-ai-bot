{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://telegram-ai-bot.local/memory/eval/fixture/schema_v1.json",
  "title": "Graph memory evaluation fixture v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fixture_id",
    "title",
    "tier",
    "language",
    "criticality",
    "slice_tags",
    "reference_time",
    "timezone",
    "users",
    "events",
    "expected",
    "review"
  ],
  "properties": {
    "schema_version": {"const": "1"},
    "fixture_id": {"$ref": "#/$defs/name"},
    "title": {"type": "string", "minLength": 1},
    "tier": {"enum": ["smoke", "full"]},
    "language": {"enum": ["ru", "en", "mixed"]},
    "criticality": {"enum": ["critical", "high", "normal"]},
    "slice_tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/name"}
    },
    "reference_time": {"type": "string", "format": "date-time"},
    "timezone": {"type": "string", "minLength": 1},
    "users": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/user"}
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {"$ref": "#/$defs/chat_event"},
          {"$ref": "#/$defs/tool_event"}
        ]
      }
    },
    "expected": {"$ref": "#/$defs/expected"},
    "review": {"$ref": "#/$defs/review"}
  },
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9_.-]*$"
    },
    "user": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_alias", "user_id"],
      "properties": {
        "user_alias": {"$ref": "#/$defs/name"},
        "user_id": {"type": "integer", "minimum": 1},
        "display_name": {"type": ["string", "null"], "minLength": 1},
        "metadata": {"type": "object"}
      }
    },
    "chat_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "kind",
        "user_alias",
        "role",
        "content",
        "content_type",
        "occurred_at",
        "metadata"
      ],
      "properties": {
        "event_id": {"$ref": "#/$defs/name"},
        "kind": {"const": "chat_message"},
        "user_alias": {"$ref": "#/$defs/name"},
        "role": {"enum": ["user", "assistant", "system", "tool"]},
        "content": {"type": "string"},
        "content_type": {"$ref": "#/$defs/name"},
        "occurred_at": {"type": "string", "format": "date-time"},
        "metadata": {"type": "object"}
      }
    },
    "tool_event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_id",
        "kind",
        "user_alias",
        "tool_name",
        "payload_kind",
        "payload_json",
        "ok",
        "cached",
        "occurred_at"
      ],
      "properties": {
        "event_id": {"$ref": "#/$defs/name"},
        "kind": {"const": "tool_result"},
        "user_alias": {"$ref": "#/$defs/name"},
        "tool_name": {"$ref": "#/$defs/name"},
        "payload_kind": {"enum": ["result", "arguments"]},
        "payload_json": {"type": "string"},
        "ok": {"type": "boolean"},
        "cached": {"type": "boolean"},
        "occurred_at": {"type": "string", "format": "date-time"}
      }
    },
    "pointer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_event"],
      "properties": {
        "source_event": {"$ref": "#/$defs/name"},
        "char_start": {"type": "integer", "minimum": 0},
        "char_end": {"type": "integer", "minimum": 1}
      },
      "dependentRequired": {
        "char_start": ["char_end"],
        "char_end": ["char_start"]
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_event",
        "source_type",
        "source_ref_alias",
        "authority_class",
        "content_hash_rule",
        "source_version_count"
      ],
      "properties": {
        "source_event": {"$ref": "#/$defs/name"},
        "source_type": {"$ref": "#/$defs/name"},
        "source_ref_alias": {"$ref": "#/$defs/name"},
        "authority_class": {"$ref": "#/$defs/name"},
        "content_hash_rule": {"$ref": "#/$defs/name"},
        "source_version_count": {"type": "integer", "minimum": 1},
        "pointer": {
          "oneOf": [
            {"$ref": "#/$defs/pointer"},
            {"type": "null"}
          ]
        },
        "normalization_job_status": {
          "oneOf": [
            {"$ref": "#/$defs/name"},
            {"type": "null"}
          ]
        }
      }
    },
    "segment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_event",
        "segment_type",
        "ordinal",
        "text",
        "normalizer_version",
        "pointer"
      ],
      "properties": {
        "source_event": {"$ref": "#/$defs/name"},
        "segment_type": {"$ref": "#/$defs/name"},
        "ordinal": {"type": "integer", "minimum": 0},
        "text": {"type": "string"},
        "normalizer_version": {"$ref": "#/$defs/name"},
        "pointer": {"$ref": "#/$defs/pointer"}
      }
    },
    "mention": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mention_id",
        "source_event",
        "mention_type",
        "surface_text",
        "char_start",
        "char_end",
        "normalized_hint",
        "pointer"
      ],
      "properties": {
        "mention_id": {"$ref": "#/$defs/name"},
        "source_event": {"$ref": "#/$defs/name"},
        "mention_type": {"$ref": "#/$defs/name"},
        "surface_text": {"type": "string", "minLength": 1},
        "char_start": {"type": "integer", "minimum": 0},
        "char_end": {"type": "integer", "minimum": 1},
        "normalized_hint": {"type": ["string", "null"]},
        "pointer": {"$ref": "#/$defs/pointer"}
      }
    },
    "argument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role"],
      "properties": {
        "role": {"$ref": "#/$defs/name"},
        "mention_ref": {"$ref": "#/$defs/name"},
        "literal": {}
      },
      "oneOf": [
        {"required": ["mention_ref"], "not": {"required": ["literal"]}},
        {"required": ["literal"], "not": {"required": ["mention_ref"]}}
      ]
    },
    "epistemic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "speaker_commitment",
        "scope",
        "alternatives",
        "needs_confirmation"
      ],
      "properties": {
        "mode": {
          "enum": ["asserted", "quoted", "reported", "observed", "inferred", "retrieved"]
        },
        "speaker_commitment": {
          "enum": ["certain", "probable", "possible", "uncertain", "unknown"]
        },
        "scope": {"enum": ["proposition", "argument", "time", "value"]},
        "alternatives": {"type": "array"},
        "needs_confirmation": {"type": "boolean"},
        "speaker_ref": {
          "oneOf": [
            {"$ref": "#/$defs/name"},
            {"type": "null"}
          ]
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_event",
        "relation",
        "exact_quote",
        "char_start",
        "char_end"
      ],
      "properties": {
        "source_event": {"$ref": "#/$defs/name"},
        "relation": {"$ref": "#/$defs/name"},
        "exact_quote": {"type": "string", "minLength": 1},
        "char_start": {"type": "integer", "minimum": 0},
        "char_end": {"type": "integer", "minimum": 1}
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_ref",
        "kind",
        "schema_name",
        "schema_version",
        "arguments",
        "attributes",
        "polarity",
        "epistemic",
        "temporal",
        "status",
        "evidence"
      ],
      "properties": {
        "candidate_ref": {"$ref": "#/$defs/name"},
        "kind": {"$ref": "#/$defs/candidate_kind"},
        "schema_name": {"$ref": "#/$defs/name"},
        "schema_version": {"$ref": "#/$defs/name"},
        "arguments": {
          "type": "array",
          "items": {"$ref": "#/$defs/argument"}
        },
        "attributes": {"type": "object"},
        "polarity": {"enum": ["positive", "negative", "unknown"]},
        "epistemic": {"$ref": "#/$defs/epistemic"},
        "temporal": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/temporal"}
          ]
        },
        "status": {"$ref": "#/$defs/name"},
        "evidence": {
          "type": "array",
          "items": {"$ref": "#/$defs/evidence"}
        },
        "allow_extra_attributes": {"type": "boolean"}
      }
    },
    "temporal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_text",
        "valid_from",
        "valid_to",
        "event_time",
        "precision",
        "timezone"
      ],
      "properties": {
        "original_text": {"type": ["string", "null"]},
        "valid_from": {"type": ["string", "null"]},
        "valid_to": {"type": ["string", "null"]},
        "event_time": {"type": ["string", "null"]},
        "precision": {"$ref": "#/$defs/name"},
        "timezone": {"type": ["string", "null"]}
      }
    },
    "forbidden_argument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role"],
      "properties": {
        "role": {"$ref": "#/$defs/name"},
        "mention_ref": {"$ref": "#/$defs/name"},
        "surface_text": {"type": "string", "minLength": 1},
        "literal": {}
      },
      "oneOf": [
        {
          "required": ["mention_ref"],
          "not": {"anyOf": [{"required": ["surface_text"]}, {"required": ["literal"]}]}
        },
        {
          "required": ["surface_text"],
          "not": {"anyOf": [{"required": ["mention_ref"]}, {"required": ["literal"]}]}
        },
        {
          "required": ["literal"],
          "not": {"anyOf": [{"required": ["mention_ref"]}, {"required": ["surface_text"]}]}
        }
      ]
    },
    "forbidden_candidate": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "kind": {"$ref": "#/$defs/candidate_kind"},
        "schema_name": {"$ref": "#/$defs/name"},
        "schema_version": {"$ref": "#/$defs/name"},
        "polarity": {"enum": ["positive", "negative", "unknown"]},
        "arguments": {
          "type": "array",
          "items": {"$ref": "#/$defs/forbidden_argument"}
        },
        "attributes": {"type": "object"}
      }
    },
    "candidate_kind": {
      "enum": [
        "entity_attribute",
        "relation",
        "preference",
        "goal",
        "task",
        "state",
        "observation",
        "correction",
        "alias",
        "document_assertion",
        "event"
      ]
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mentions", "candidates", "expect_abstention"],
      "properties": {
        "sources": {
          "type": "array",
          "items": {"$ref": "#/$defs/source"}
        },
        "segments": {
          "type": "array",
          "items": {"$ref": "#/$defs/segment"}
        },
        "mentions": {
          "type": "array",
          "items": {"$ref": "#/$defs/mention"}
        },
        "candidates": {
          "type": "array",
          "items": {"$ref": "#/$defs/candidate"}
        },
        "forbidden_candidates": {
          "type": "array",
          "items": {"$ref": "#/$defs/forbidden_candidate"}
        },
        "forbidden_sources": {
          "type": "array",
          "items": {"$ref": "#/$defs/forbidden_source"}
        },
        "forbidden_segments": {
          "type": "array",
          "items": {"$ref": "#/$defs/forbidden_segment"}
        },
        "expect_abstention": {"type": "boolean"}
      }
    },
    "forbidden_source": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "source_event": {"$ref": "#/$defs/name"},
        "source_type": {"$ref": "#/$defs/name"},
        "authority_class": {"$ref": "#/$defs/name"}
      }
    },
    "forbidden_segment": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "source_event": {"$ref": "#/$defs/name"},
        "segment_type": {"$ref": "#/$defs/name"},
        "text": {"type": "string"}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_by", "reviewed_at", "notes"],
      "properties": {
        "status": {"enum": ["draft", "reviewed"]},
        "reviewed_by": {"type": ["string", "null"]},
        "reviewed_at": {"type": ["string", "null"], "format": "date-time"},
        "notes": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    }
  }
}
