# --- Required secrets ---
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
OPENAI_API_KEY=your_fireworks_api_key
EXA_API_KEY=your_exa_api_key
GROQ_API_KEY=your_groq_api_key

# --- LLM ---
OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1
OPENAI_MODEL=accounts/fireworks/models/glm-5p2
# Reasoning depth for thinking models (Fireworks: low | medium | high)
REASONING_EFFORT=medium
# Lightweight model for tool-result + worker planning summaries (not the agent)
SUMMARIZE_BASE_URL=https://api.fireworks.ai/inference/v1
SUMMARIZE_API_KEY=your_fireworks_api_key
SUMMARIZE_MODEL=accounts/fireworks/models/deepseek-v4-flash

# Trajectory coach — periodic strategy review (uses SUMMARIZE_* model)
AGENT_COACH_ENABLED=1
COACH_EVERY_N_TOOL_CALLS=5
COACH_MAX_FIELD_CHARS=700
COACH_MAX_TRACE_CHARS=60000
COACH_INJECT_HINTS=1
COACH_MAX_OUTPUT_TOKENS=8192

# Tool checker — per-tool verification after use_tool (uses CHECKER_* or SUMMARIZE_*)
AGENT_CHECKER_ENABLED=1
CHECKER_TOOLS_ALLOWLIST=*
CHECKER_SKIP_CACHED=1
AGENT_CHECKER_DEBUG=0

# Thorough multi-agent system (not wired to Telegram bot yet).
# Empty BASE_URL/API_KEY → SUMMARIZE_*; MODEL has per-role defaults below.
THOROUGH_ENABLED=0
# P1 — unit / substance planner (Kimi K2.6)
THOROUGH_PLANNER_UNIT_BASE_URL=
THOROUGH_PLANNER_UNIT_API_KEY=
THOROUGH_PLANNER_UNIT_MODEL=accounts/fireworks/models/kimi-k2p6
# P2 — surface / delivery planner (GLM 5.2)
THOROUGH_PLANNER_SURFACE_BASE_URL=
THOROUGH_PLANNER_SURFACE_API_KEY=
THOROUGH_PLANNER_SURFACE_MODEL=accounts/fireworks/models/glm-5p2
# P3 — hot-window / context planner (Qwen3.7 Plus)
THOROUGH_PLANNER_HOT_BASE_URL=
THOROUGH_PLANNER_HOT_API_KEY=
THOROUGH_PLANNER_HOT_MODEL=accounts/fireworks/models/qwen3p7-plus
# M — phase plan merger (GLM 5.2)
THOROUGH_MERGER_BASE_URL=
THOROUGH_MERGER_API_KEY=
THOROUGH_MERGER_MODEL=accounts/fireworks/models/glm-5p2
# Max output tokens (phase 1 planners / phase 2 merger)
THOROUGH_PLANNER_MAX_OUTPUT_TOKENS=4096
THOROUGH_MERGER_MAX_OUTPUT_TOKENS=8192

LLM_REQUEST_TIMEOUTS=30,60,90
SYSTEM_PROMPT=You are a helpful AI assistant in Telegram. Reply using Telegram Rich Markdown: GFM tables, $inline math$, $$block math$$, headings, lists, bold/italic/code. Use tables and formulas when helpful.
AGENT_MAX_TOOL_TURNS=200
AGENT_SUPERVISOR_ENABLED=1
AGENT_SUPERVISOR_BONUS_TURNS=60
AGENT_SUPERVISOR_MAX_CYCLES=20
AGENT_SUPERVISOR_TRACE_MAX_CHARS=12000
AGENT_SUPERVISOR_SOFT_TRIGGERS=1
AGENT_SUPERVISOR_PERIODIC_EVERY=0
AGENT_SUPERVISOR_MAX_RETRIES=1
AGENT_SUPERVISOR_DEBUG_TRACE=0

# Auto-load skill playbook after N distinct tools in one area (per run or history).
SKILLS_AUTO_LOAD_DISTINCT_TOOLS=3
SKILLS_COLLAPSE_IDLE_TURNS=7

# --- Bot runtime ---
BOT_TIMEZONE=Asia/Tashkent
ADMIN_USER_IDS=123456789
# Comma-separated Telegram user ids allowed to use the bot without approval.
ALLOWED_USER_IDS=123456789,987654321
# Require admin approval for users not in ALLOWED_USER_IDS / ADMIN_USER_IDS.
ACCESS_APPROVAL_ENABLED=1
ACCESS_DB_PATH=data/access.sqlite

# --- Graph memory (PR 0 foundation — disabled; does not affect Telegram replies) ---
MEMORY_INGEST_ENABLED=0
MEMORY_DB_PATH=data/memory.sqlite
MEMORY_WORKER_ENABLED=0
MEMORY_WORKER_CONCURRENCY=2
MEMORY_WORKER_POLL_SECONDS=1.0
MEMORY_JOB_LEASE_SECONDS=300
MEMORY_JOB_MAX_ATTEMPTS=5
MEMORY_JOB_RETRY_BASE_SECONDS=5
MEMORY_JOB_RETRY_MAX_SECONDS=900
MEMORY_JOB_CLAIM_BATCH_SIZE=10
MEMORY_INGEST_QUEUE_MAXSIZE=1000
MEMORY_INGEST_SCAN_INTERVAL_SECONDS=30
MEMORY_INGEST_SCAN_BATCH_SIZE=100
MEMORY_INGEST_FAILURE_MAX_ATTEMPTS=10
MEMORY_INGEST_RETRY_BASE_SECONDS=5
MEMORY_INGEST_RETRY_MAX_SECONDS=900
MEMORY_TEXT_SEGMENT_CHARS=4000
MEMORY_TEXT_SEGMENT_OVERLAP=200
MEMORY_TOOL_RECONCILE_BATCH_SIZE=100
MEMORY_INGEST_SHUTDOWN_GRACE_SECONDS=10
# PR 3 shadow extraction. Requires MEMORY_WORKER_ENABLED=1; never affects replies.
MEMORY_EXTRACTION_ENABLED=0
MEMORY_EXTRACTION_MODEL_PROFILE=extraction
MEMORY_EXTRACTION_MAX_TOKENS=4096
# PR 4 shadow verification. Requires MEMORY_WORKER_ENABLED=1; never affects replies.
MEMORY_VERIFICATION_ENABLED=0
MEMORY_VERIFICATION_SUPPORT_MODEL_PROFILE=extraction
MEMORY_VERIFICATION_ADVERSARIAL_MODEL_PROFILE=agent
MEMORY_VERIFICATION_MAX_TOKENS=2048
MEMORY_VERIFICATION_SCAN_INTERVAL_SECONDS=30
MEMORY_VERIFICATION_SCAN_BATCH_SIZE=100
MEMORY_VERIFICATION_CONTEXT_CHARS=240
MEMORY_VERIFICATION_POLICY_VERSION=verification_policy_v2
# PR 5/7 shadow resolution (+ temporal reconciliation). Requires worker+verification.
MEMORY_RESOLUTION_ENABLED=0
MEMORY_RESOLUTION_SCAN_INTERVAL_SECONDS=30
MEMORY_RESOLUTION_SCAN_BATCH_SIZE=100
MEMORY_REQUIRED_VERIFICATION_POLICY_VERSION=verification_policy_v2
MEMORY_RESOLUTION_LINK_SUPPORT_MODEL_PROFILE=extraction
MEMORY_RESOLUTION_LINK_ADVERSARIAL_MODEL_PROFILE=agent
MEMORY_RESOLUTION_MAX_TOKENS=1536
# PR 11 full entity resolution (opt-in; defaults keep PR5 classic path)
MEMORY_RESOLUTION_CANDIDATE_GENERATION_ENABLED=0
MEMORY_RESOLUTION_FUZZY_BLOCKING_ENABLED=0
MEMORY_RESOLUTION_FUZZY_MIN_TRIGRAM=0.6
MEMORY_RESOLUTION_CROSS_LANGUAGE_ENABLED=0
MEMORY_RESOLUTION_CLUSTER_CRITIC_ENABLED=0
MEMORY_RESOLUTION_MERGE_EVENTS_ENABLED=0
MEMORY_RESOLUTION_RELINK_ON_INVALIDATION=0
MEMORY_RESOLUTION_MAX_CANDIDATES=8
# PR 6 shadow graph. Requires MEMORY_RESOLUTION_ENABLED=1.
MEMORY_GRAPH_ENABLED=0
MEMORY_GRAPH_SCAN_INTERVAL_SECONDS=30
MEMORY_GRAPH_SCAN_BATCH_SIZE=100
# PR 12 summaries + communities (shadow-only). Requires MEMORY_GRAPH_ENABLED=1 + worker.
MEMORY_SUMMARIES_ENABLED=0
MEMORY_SUMMARIES_GENERATION_ENABLED=0
MEMORY_SUMMARIES_VERIFY_ENABLED=1
MEMORY_SUMMARIES_COMMUNITIES_ENABLED=0
MEMORY_SUMMARIES_SHADOW_PACK_ENABLED=0
MEMORY_SUMMARIES_SCAN_INTERVAL_SECONDS=30
MEMORY_SUMMARIES_SCAN_BATCH_SIZE=50
MEMORY_SUMMARIES_DEBOUNCE_SECONDS=120
MEMORY_SUMMARIES_FULL_REBUILD_EVERY_N=50
MEMORY_SUMMARIES_MODEL_PROFILE=summarize
MEMORY_SUMMARIES_VERIFY_MODEL_PROFILE=extraction
MEMORY_SUMMARIES_MAX_TOKENS=2048
MEMORY_SUMMARIES_COMMUNITY_LABEL_ENABLED=0

# PR14 attachment engine (shadow-only; requires graph+worker+resolution)
MEMORY_ATTACHMENT_ENABLED=0
MEMORY_ATTACHMENT_GENERATION_ENABLED=0
MEMORY_ATTACHMENT_VERIFY_ENABLED=1
MEMORY_ATTACHMENT_TWO_GENERATOR_ENABLED=0
MEMORY_ATTACHMENT_VECTOR_ENABLED=1
MEMORY_ATTACHMENT_CURATED_TAXONOMY_ENABLED=1
MEMORY_ATTACHMENT_INFERRED_PREFERENCE_ENABLED=1
MEMORY_ATTACHMENT_WRITE_GRAPH_EDGES=1
MEMORY_ATTACHMENT_WRITE_POSSIBLE_EVENTS=0
MEMORY_ATTACHMENT_SCAN_INTERVAL_SECONDS=30
MEMORY_ATTACHMENT_SCAN_BATCH_SIZE=20
MEMORY_ATTACHMENT_DEBOUNCE_SECONDS=2
MEMORY_ATTACHMENT_MAX_CANDIDATES=12
MEMORY_ATTACHMENT_MAX_LLM_CALLS=6
MEMORY_ATTACHMENT_MODEL_PROFILE=extraction
MEMORY_ATTACHMENT_SUPPORT_MODEL_PROFILE=extraction
MEMORY_ATTACHMENT_ADVERSARIAL_MODEL_PROFILE=agent
MEMORY_ATTACHMENT_CLUSTER_MODEL_PROFILE=agent
MEMORY_ATTACHMENT_MAX_TOKENS=1536
# Read-only ReAct graph research. v1 supports shadow mode only and never alters writes.
MEMORY_ATTACHMENT_REACT_ENABLED=0
MEMORY_ATTACHMENT_REACT_MODE=shadow
MEMORY_ATTACHMENT_REACT_MODEL_PROFILE=agent
MEMORY_ATTACHMENT_REACT_MAX_ACTIONS=10
MEMORY_ATTACHMENT_REACT_MAX_HOPS=3
MEMORY_ATTACHMENT_REACT_MAX_RESULTS=10
MEMORY_ATTACHMENT_REACT_MAX_NODES=60
MEMORY_ATTACHMENT_REACT_MAX_TOKENS=4096
# PR 8 shadow retrieval. Never mutates Telegram prompts. Requires resolution or graph.
MEMORY_SHADOW_RETRIEVAL_ENABLED=0
MEMORY_SHADOW_RETRIEVAL_TIMEOUT_SECONDS=2.0
MEMORY_SHADOW_RETRIEVAL_TOKEN_BUDGET=4000
MEMORY_SHADOW_RETRIEVAL_MAX_BELIEFS=24
MEMORY_SHADOW_RETRIEVAL_MAX_HOPS=3
# PR 9 documents. Registers PDF/DOCX uploads into memory structure jobs (shadow).
MEMORY_DOCUMENTS_ENABLED=0
#
# Shadow production stack (still never injects into Telegram replies):
#   MEMORY_INGEST_ENABLED=1
#   MEMORY_WORKER_ENABLED=1
#   MEMORY_EXTRACTION_ENABLED=1
#   MEMORY_VERIFICATION_ENABLED=1
#   MEMORY_RESOLUTION_ENABLED=1
#   MEMORY_GRAPH_ENABLED=1
#   MEMORY_SHADOW_RETRIEVAL_ENABLED=1
#   MEMORY_DOCUMENTS_ENABLED=1
# Startup validate_memory_config enforces: worker if extract/verify/resolve/documents;
# verify if resolve; matching verification policy versions; resolution if graph;
# resolution|graph if shadow retrieval.
# Ops: /memory_status (admin) shows stage flags + assertion/belief/graph counts.

CHAT_DB_PATH=data/chat.sqlite
# Legacy v1 blob DB — read once by migration on startup (fallback: CHAT_HISTORY_DB_PATH)
CHAT_MIGRATE_V1_SOURCE_PATH=data/chat_history.sqlite
CHAT_SESSION_SUMMARY_ON_ARCHIVE=1
CHAT_SESSION_SUMMARY_MAX_INPUT_CHARS=80000
CHAT_SESSION_SUMMARY_PER_TURN_MAX_CHARS=12000
# Precomputed day/week/month digests from session summaries (BOT_TIMEZONE boundaries)
CHAT_PERIOD_SUMMARY_ENABLED=1
CHAT_PERIOD_SUMMARY_ON_SESSION_ARCHIVE=1
CHAT_PERIOD_SUMMARY_MAX_INPUT_CHARS=120000
# Close previous day/week/month digests when the boundary passes (BOT_TIMEZONE)
CHAT_PERIOD_SUMMARY_BOUNDARY_ENABLED=1
CHAT_PERIOD_SUMMARY_BOUNDARY_POLL_SECONDS=60
# Archive active chat sessions at local day boundary (feeds day period digests).
CHAT_DAY_ARCHIVE_ENABLED=1
CHAT_MIGRATE_V1_ON_STARTUP=1
CHAT_MIGRATE_V1_TARGET=active
CHAT_MIGRATE_V1_BACKUP=1
CHAT_SEARCH_CHUNK_CHARS=800
CHAT_SEARCH_CHUNK_OVERLAP=100
CHAT_SEARCH_TOP_K=5
CHAT_SEARCH_KEYWORD_CANDIDATES=80
CHAT_SEARCH_VECTOR_SCAN_LIMIT=2000
CHAT_SEARCH_MAX_PER_SESSION=5
CHAT_INDEX_ON_STARTUP=1
CHAT_INDEX_PAYLOAD_MAX_CHARS=4000
INSTANCE_LOCK_ENABLED=1
INSTANCE_LOCK_PATH=data/bot.instance.lock

# --- Chat history & message gaps ---
CHAT_MAX_HISTORY=50
MESSAGE_GAP_MINUTES=20
# Inject quoted-message context when user replies to a specific Telegram message.
TELEGRAM_REPLY_CONTEXT_ENABLED=1
TELEGRAM_REPLY_TURN_RADIUS=5

# --- Message queue & burst grouping (Telegram split paste) ---
QUEUE_MAX_PENDING=10
MESSAGE_BURST_QUIET_MS=150
MESSAGE_BURST_MAX_WAIT_MS=600
TELEGRAM_SPLIT_MIN_CHARS=3500

# --- Telegram message limits ---
TELEGRAM_RICH_LIMIT=32768
TELEGRAM_PLAIN_LIMIT=4096
DRAFT_UPDATE_INTERVAL=0.35
DRAFT_KEEPALIVE_INTERVAL=20
DRAFT_TYPING_INTERVAL=5

# --- Vision ---
IMAGE_MAX_BYTES=10485760

# --- Voice (Groq Whisper) ---
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo
# Optional ISO-639-1 code, e.g. ru, en — leave empty for auto-detect
GROQ_TRANSCRIPTION_LANGUAGE=

# --- Tool embeddings ---
EMBEDDING_BASE_URL=https://api.fireworks.ai/inference/v1
EMBEDDING_API_KEY=your_fireworks_api_key
OPENAI_EMBEDDING_MODEL=fireworks/qwen3-embedding-8b
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
TOOL_EMBEDDING_PROVIDER=api

# Google OAuth / Calendar — Cal-1 (OAuth + read tools)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Desktop OAuth: redirect to localhost, user pastes callback URL into bot.
GOOGLE_OAUTH_CLIENT_TYPE=installed
GOOGLE_REDIRECT_URI=http://localhost:1
# Optional: public HTTPS callback server (no paste needed). Requires Web OAuth client.
# GOOGLE_PUBLIC_BASE_URL=https://hermes.example.com
GOOGLE_OAUTH_HOST=127.0.0.1
GOOGLE_OAUTH_PORT=8787
GOOGLE_TOKEN_DB_PATH=data/google_tokens.sqlite
# Direct link for admin «Test users» button (optional override).
# GOOGLE_CLOUD_TEST_USERS_URL=https://console.cloud.google.com/apis/credentials/consent?project=my-project
GOOGLE_CLOUD_PROJECT_ID=
# Optional: service account JSON for real Test users auto-check (roles/oauthconfig.viewer).
# GOOGLE_TEST_USERS_VERIFY_SA_PATH=secrets/gcp-oauthconfig-viewer.json
# Fallback when GCP API недоступен: доверять кнопке админа (1=да, 0=только через API).
GOOGLE_TEST_USER_VERIFY_TRUST_ADMIN=1
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar,https://www.googleapis.com/auth/gmail.modify,https://www.googleapis.com/auth/gmail.settings.basic,https://www.googleapis.com/auth/drive,https://www.googleapis.com/auth/spreadsheets,https://www.googleapis.com/auth/tasks

# Gmail (OAuth — same connect as Calendar)
GMAIL_MAX_BODY_CHARS=4000
GMAIL_MAX_ATTACHMENT_BYTES=5242880
GMAIL_DEFAULT_MAX_RESULTS=10
GMAIL_RATE_LIMIT_READ=120/60
GMAIL_RATE_LIMIT_WRITE=60/60

# Google Drive (OAuth — same connect as Calendar + Gmail)
DRIVE_MAX_DOWNLOAD_BYTES=10485760
DRIVE_MAX_UPLOAD_BYTES=10485760
DRIVE_MAX_EXPORT_CHARS=50000
DRIVE_DEFAULT_MAX_RESULTS=10
DRIVE_RATE_LIMIT_READ=120/60
DRIVE_RATE_LIMIT_WRITE=60/60

# Google Sheets (OAuth — same connect as Calendar + Gmail + Drive)
SHEETS_MAX_CELLS=10000
SHEETS_RATE_LIMIT_READ=120/60
SHEETS_RATE_LIMIT_WRITE=60/60

# Google Maps Platform — API key (same GCP project as Calendar)
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_DEFAULT_LANGUAGE=ru
GOOGLE_MAPS_DEFAULT_REGION=uz
GOOGLE_MAPS_DEFAULT_LAT=41.2995
GOOGLE_MAPS_DEFAULT_LNG=69.2401
MAPS_RATE_LIMIT_GEOCODE=60/60
MAPS_RATE_LIMIT_PLACES=30/60
MAPS_RATE_LIMIT_DETAILS=40/60
MAPS_RATE_LIMIT_ROUTES=20/60
MAPS_RATE_LIMIT_STATIC=10/60
MAPS_RATE_LIMIT_DEFAULT=120/3600

# Transit route button: google (Google Maps URL) or yandex (Yandex Maps URL, Tashkent-friendly)
MAPS_TRANSIT_LINK_PROVIDER=yandex

# Yandex Music — device OAuth tokens (SQLite), language for API responses
YANDEX_TOKEN_DB_PATH=data/yandex_tokens.sqlite
YANDEX_MUSIC_LANGUAGE=ru
YANDEX_MUSIC_RATE_LIMIT_READ=120/60
YANDEX_MUSIC_RATE_LIMIT_WRITE=60/60

TOOL_CACHE_MAX_TTL=86400
EXA_SEARCH_CACHE_TTL=300
EXA_FETCH_CACHE_TTL=3600
RATE_LIMIT_EXA_SEARCH=240/60
RATE_LIMIT_EXA_FETCH=400/60
MAX_TOOL_CALLS_PER_USER_HOUR=200

# --- PDF tools ---
PDF_RATE_LIMIT_READ=60/60
PDF_MAX_TEXT_CHARS_PER_PAGE=8000
PDF_MAX_TABLES=20
PDF_MAX_IMAGES=20
PDF_MAX_SEARCH_RESULTS=50

# --- PDF OCR (Mistral OCR 4 API: POST /v1/ocr) ---
OCR_BASE_URL=https://api.mistral.ai/v1
OCR_API_KEY=your_mistral_api_key
OCR_MODEL=mistral-ocr-latest
OCR_MAX_PAGES=50
OCR_RATE_LIMIT=20/60
